          "transcripts": [
            {
              "startMs": 0,
              "endMs": 3297,
              "text": "Excuse me, how do I get to the science museum from here?",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "저기요, 여기서 과학 박물관까지 어떻게 가요?"
              }
            },
            {
              "startMs": 3697,
              "endMs": 6808,
              "text": "Sure, take the number twelve bus heading north for about four stops.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "네, 북쪽으로 가는 12번 버스를 타고 약 네 정거장 가세요."
              }
            },
            {
              "startMs": 7208,
              "endMs": 9902,
              "text": "Then transfer to the blue line train at Central Station.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "그 다음에 중앙역에서 파란색 라인 전철로 갈아타세요."
              }
            },
            {
              "startMs": 10302,
              "endMs": 11788,
              "text": "How many stops on the train?",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "전철은 몇 정거장이요?"
              }
            },
            {
              "startMs": 12188,
              "endMs": 14789,
              "text": "Just three stops, get off at University Avenue.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "세 정거장만 가시면 되고, 유니버시티 애비뉴에서 내리세요."
              }
            },
            {
              "startMs": 15189,
              "endMs": 17883,
              "text": "From there, it's about a ten minute walk to the museum.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "거기서 박물관까지는 걸어서 약 10분 걸려요."
              }
            },
            {
              "startMs": 18283,
              "endMs": 20466,
              "text": "That sounds easy enough, thank you so much!",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "충분히 쉬울 것 같네요, 정말 감사합니다!"
              }
            },
            {
              "startMs": 20866,
              "endMs": 22491,
              "text": "No problem, have a great visit!",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "별 말씀을요, 즐거운 관람 되세요!"
              }
            }
          ]
        }
