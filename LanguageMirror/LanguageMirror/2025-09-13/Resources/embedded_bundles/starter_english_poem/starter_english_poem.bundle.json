          "transcripts": [
            {
              "startMs": 0,
              "endMs": 1533,
              "text": "Hope is the thing with feathers",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "희망은 깃털을 가진 것"
              }
            },
            {
              "startMs": 1933,
              "endMs": 3419,
              "text": "That perches in the soul,",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "영혼 속에 앉아 있는"
              }
            },
            {
              "startMs": 3819,
              "endMs": 5584,
              "text": "And sings the tune without the words,",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "그리고 말 없는 노래를 부르는"
              }
            },
            {
              "startMs": 5984,
              "endMs": 7284,
              "text": "And never stops at all,",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "그리고 결코 멈추지 않는"
              }
            },
            {
              "startMs": 7684,
              "endMs": 9542,
              "text": "And sweetest in the gale is heard;",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "그리고 폭풍 속에서 가장 달콤하게 들리는"
              }
            },
            {
              "startMs": 9942,
              "endMs": 11382,
              "text": "And sore must be the storm",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "그리고 얼마나 거센 폭풍이어야 할까"
              }
            },
            {
              "startMs": 11782,
              "endMs": 13640,
              "text": "That could abash the little bird",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "그 작은 새를 주눅들게 할 수 있을"
              }
            },
            {
              "startMs": 14040,
              "endMs": 15480,
              "text": "That kept so many warm.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "그토록 많은 이를 따뜻하게 해준"
              }
            },
            {
              "startMs": 15880,
              "endMs": 17645,
              "text": "I've heard it in the chillest land,",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "나는 그것을 가장 추운 땅에서 들었고"
              }
            },
            {
              "startMs": 18045,
              "endMs": 19531,
              "text": "And on the strangest sea;",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "그리고 가장 낯선 바다 위에서도"
              }
            },
            {
              "startMs": 19931,
              "endMs": 21510,
              "text": "Yet, never, in extremity,",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "하지만 결코, 극한의 순간에도"
              }
            },
            {
              "startMs": 21910,
              "endMs": 23210,
              "text": "It asked a crumb of me.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "그것은 내게 빵 부스러기 하나 요구하지 않았다"
              }
            }
          ]
        }
      ]
