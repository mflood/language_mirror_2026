          "transcripts": [
            {
              "startMs": 0,
              "endMs": 3204,
              "text": "I wake up slowly to the sound of rain on the windows.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "창문에 떨어지는 빗소리에 천천히 잠에서 깨어났어요."
              }
            },
            {
              "startMs": 3604,
              "endMs": 5833,
              "text": "It's Sunday, and I have nowhere to be.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "일요일이라 갈 곳이 없어요."
              }
            },
            {
              "startMs": 6233,
              "endMs": 9298,
              "text": "I make myself a cup of coffee in the quiet kitchen.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "조용한 부엌에서 커피 한 잔을 만들었어요."
              }
            },
            {
              "startMs": 9698,
              "endMs": 12299,
              "text": "I sit by the window and watch the rain fall.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "창가에 앉아서 비가 내리는 걸 바라봤어요."
              }
            },
            {
              "startMs": 12699,
              "endMs": 15021,
              "text": "The street outside is empty and peaceful.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "밖의 거리는 텅 비어 있고 평화로웠어요."
              }
            },
            {
              "startMs": 15421,
              "endMs": 17604,
              "text": "I think about the busy week behind me.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "지나간 바쁜 한 주를 생각했어요."
              }
            },
            {
              "startMs": 18004,
              "endMs": 21626,
              "text": "Right now, in this moment, everything feels perfectly still.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "지금 이 순간, 모든 것이 완벽하게 고요하게 느껴져요."
              }
            },
            {
              "startMs": 22026,
              "endMs": 24023,
              "text": "I'm grateful for this quiet morning.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "이 조용한 아침이 감사해요."
              }
            }
          ]
        }
