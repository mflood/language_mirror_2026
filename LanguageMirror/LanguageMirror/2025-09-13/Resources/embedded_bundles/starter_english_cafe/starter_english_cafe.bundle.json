          "transcripts": [
            {
              "startMs": 0,
              "endMs": 3019,
              "text": "Hi, I'd like a coffee, but I'm not sure what to get.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "안녕하세요, 커피를 마시고 싶은데 뭘 주문할지 잘 모르겠어요."
              }
            },
            {
              "startMs": 3419,
              "endMs": 6391,
              "text": "Our cappuccino is really popular, and so is the cold brew.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "저희 카푸치노가 정말 인기가 많고, 콜드브루도 인기가 많아요."
              }
            },
            {
              "startMs": 6791,
              "endMs": 8509,
              "text": "I'll try the cappuccino, please.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "카푸치노로 할게요."
              }
            },
            {
              "startMs": 8909,
              "endMs": 11092,
              "text": "Great choice! Would you like a pastry with that?",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "좋은 선택이세요! 페이스트리도 함께 드시겠어요?"
              }
            },
            {
              "startMs": 11492,
              "endMs": 12746,
              "text": "What do you recommend?",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "뭘 추천하시나요?"
              }
            },
            {
              "startMs": 13146,
              "endMs": 16722,
              "text": "The blueberry muffins are fresh this morning, and they're delicious.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "블루베리 머핀이 오늘 아침에 나온 신선한 거고, 정말 맛있어요."
              }
            },
            {
              "startMs": 17122,
              "endMs": 19072,
              "text": "Perfect, I'll take one of those.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "좋아요, 그것으로 하나 주세요."
              }
            },
            {
              "startMs": 19472,
              "endMs": 21655,
              "text": "Sounds good! Is this for here or to go?",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "좋아요! 매장에서 드시나요, 가져가시나요?"
              }
            },
            {
              "startMs": 22055,
              "endMs": 23541,
              "text": "For here, thanks.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "매장에서 먹을게요, 감사합니다."
              }
            }
          ]
