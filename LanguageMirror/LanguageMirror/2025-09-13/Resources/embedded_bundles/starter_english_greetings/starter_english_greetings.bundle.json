          "transcripts": [
            {
              "startMs": 0,
              "endMs": 2090,
              "text": "What a beautiful day for the market!",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "장보기 정말 좋은 날이다!"
              }
            },
            {
              "startMs": 2490,
              "endMs": 3976,
              "text": "I know, the weather is perfect.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "그러게, 날씨 완벽하네."
              }
            },
            {
              "startMs": 4376,
              "endMs": 5769,
              "text": "I'm Sarah, by the way.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "참, 난 사라야."
              }
            },
            {
              "startMs": 6169,
              "endMs": 8073,
              "text": "Nice to meet you, Sarah. I'm Tom.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "반가워, 사라. 난 톰이야."
              }
            },
            {
              "startMs": 8473,
              "endMs": 9913,
              "text": "Are you from around here?",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "여기 사는 사람이야?"
              }
            },
            {
              "startMs": 10313,
              "endMs": 12960,
              "text": "Actually, I just moved here from Chicago last month.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "사실 지난달에 시카고에서 여기로 이사 왔어."
              }
            },
            {
              "startMs": 13360,
              "endMs": 16425,
              "text": "Oh wow, welcome! I've lived here my whole life.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "오 진짜, 환영해! 난 여기서 쭉 살았어."
              }
            },
            {
              "startMs": 16825,
              "endMs": 18729,
              "text": "That's cool. So what do you do for work?",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "좋네. 그럼 무슨 일 해?"
              }
            },
            {
              "startMs": 19129,
              "endMs": 21079,
              "text": "I'm a teacher at the local high school.",
              "speaker": "Speaker 1",
              "languageCode": "en-US",
              "translations": {
                "ko": "나 동네 고등학교에서 선생님이야."
              }
            },
            {
              "startMs": 21479,
              "endMs": 23244,
              "text": "Nice! I work in graphic design.",
              "speaker": "Speaker 2",
              "languageCode": "en-US",
              "translations": {
                "ko": "좋네! 난 그래픽 디자인 일 해."
