{
  "language": "ko-KR",
  "turns": [
    {
      "turn": 0,
      "speaker": "A",
      "voice": "Seoyeon",
      "text": "실례합니다, 이 근처에 점심 먹을 만한 좋은 식당 있을까요?",
      "startMs": 0,
      "endMs": 4248,
      "approx": false
    },
    {
      "turn": 1,
      "speaker": "B",
      "voice": "Jihye",
      "text": "네, 있어요! 어떤 음식을 좋아하세요?",
      "startMs": 4648,
      "endMs": 7624,
      "approx": false
    },
    {
      "turn": 2,
      "speaker": "A",
      "voice": "Seoyeon",
      "text": "한국 음식이면 다 좋아하는데, 매운 음식은 조금 어려워요.",
      "startMs": 8024,
      "endMs": 12392,
      "approx": false
    },
    {
      "turn": 3,
      "speaker": "B",
      "voice": "Jihye",
      "text": "그러면 역 2번 출구 근처에 삼계탕 집이 정말 맛있어요.",
      "startMs": 12792,
      "endMs": 17112,
      "approx": false
    },
    {
      "turn": 4,
      "speaker": "A",
      "voice": "Seoyeon",
      "text": "오, 좋네요! 거기 사람이 많이 붐비나요?",
      "startMs": 17512,
      "endMs": 21136,
      "approx": false
    },
    {
      "turn": 5,
      "speaker": "B",
      "voice": "Jihye",
      "text": "점심시간에는 좀 붐비지만 회전이 빨라서 금방 앉을 수 있어요.",
      "startMs": 21536,
      "endMs": 26072,
      "approx": false
    },
    {
      "turn": 6,
      "speaker": "A",
      "voice": "Seoyeon",
      "text": "조용한 곳을 더 선호하는데, 다른 곳도 있을까요?",
      "startMs": 26472,
      "endMs": 30120,
      "approx": false
    },
    {
      "turn": 7,
      "speaker": "B",
      "voice": "Jihye",
      "text": "그럼 4번 출구 쪽에 작은 비빔밥 식당이 있어요.",
      "startMs": 30520,
      "endMs": 33904,
      "approx": false
    },
    {
      "turn": 8,
      "speaker": "A",
      "voice": "Seoyeon",
      "text": "거기는 분위기가 어때요?",
      "startMs": 34304,
      "endMs": 36248,
      "approx": false
    },
    {
      "turn": 9,
      "speaker": "B",
      "voice": "Jihye",
      "text": "아늑하고 조용해서 천천히 식사하기 좋아요.",
      "startMs": 36648,
      "endMs": 39744,
      "approx": false
    },
    {
      "turn": 10,
      "speaker": "A",
      "voice": "Seoyeon",
      "text": "완벽하네요! 거기로 가볼게요. 정말 감사합니다!",
      "startMs": 40144,
      "endMs": 45304,
      "approx": false
    },
    {
      "turn": 11,
      "speaker": "B",
      "voice": "Jihye",
      "text": "천만에요. 맛있게 드세요!",
      "startMs": 45704,
      "endMs": 48080,
      "approx": false
    }
  ]
}
